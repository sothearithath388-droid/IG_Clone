# Copy this file to .env and fill in the values for local development
# NEVER commit the real .env file to git

SECRET_KEY=django-insecure-local-dev-key-replace-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Leave blank locally — Django will use SQLite automatically
DATABASE_URL=
